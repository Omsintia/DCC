# ---- .NET build output ----
[Bb]in/
[Oo]bj/
[Oo]ut/
*.user
*.suo
.vs/
artifacts/
publish/
TestResults/

# ---- Rider / VS Code ----
.idea/
*.DotSettings.user

# ---- Secrets / signing material (never commit) ----
# Private key material is ignored by EXTENSION so it can never be committed from anywhere in the tree.
# (Do NOT add a bare `signing/` here: it would also swallow tools/signing/ - the scripts + the PUBLIC
# .cer/thumbprint reference that MUST ship. tools/signing/.gitignore ignores only the release/ output.)
*.pfx
*.snk
*.pem
*.key
*.p12

# ---- Misc ----
*.tmp
*.log
Thumbs.db

# WPF SDK transient temp project files
*_wpftmp.csproj

# Generated wizard-bitmap previews (regenerated by the packaging scripts)
tools/packaging/assets/*.preview.png
