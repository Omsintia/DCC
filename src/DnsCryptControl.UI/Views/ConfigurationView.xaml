<UserControl x:Class="DnsCryptControl.UI.Views.ConfigurationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:DnsCryptControl.UI.Converters"
    xmlns:vm="clr-namespace:DnsCryptControl.UI.ViewModels"
    mc:Ignorable="d"
    d:DesignHeight="720" d:DesignWidth="1000">

    <UserControl.Resources>
        <converters:StringArrayToLinesConverter x:Key="ArrayToLines" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <converters:DeprecatedChipTextConverter x:Key="DeprecatedChipText" />
        <converters:SeverityToGlyphConverter x:Key="SeverityToGlyph" />
        <converters:ConfigStatusBadgeConverter x:Key="StatusBadge" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Structured editors (F1): each SettingValueType gets its own template; the
             row's ContentControl picks one via DataTriggers (IsRawOnly LAST so it wins
             over the type template — P5b-E3: Table types and dynamic sections are
             raw-only in 5b). Commits go through code-behind -> StructuredEditCommit ->
             ApplyEdit ONLY (IC-1: the doc is the single source of truth); the TwoWay
             bindings are UpdateSourceTrigger=Explicit and never update the source. -->
        <DataTemplate x:Key="BoolEditorTemplate">
            <!-- Click drives the commit (mirrors Dashboard's command-driven toggle); IsChecked one-way
                 projects the EFFECTIVE value (doc value if set, else the catalog default) so an unset
                 default-true key shows "on" instead of a misleading "off" under "Default: true" (5j).
                 ToggleButton toggles via SetCurrentValue, so the one-way binding survives user clicks;
                 BoolEditor_Click reads the toggle's own state, so the commit is unaffected. -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <ui:ToggleSwitch IsChecked="{Binding EffectiveBool, Mode=OneWay}"
                                 OnContent="on" OffContent="off"
                                 Click="BoolEditor_Click"
                                 VerticalAlignment="Center" />
                <!-- 5j: marks an UNSET key so "on" reads as "the default", not your explicit choice —
                     the bool analogue of the number/string editors' PlaceholderText=default cue. -->
                <TextBlock Text="(default)" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           ToolTip="This setting isn't in your config file — the switch shows dnscrypt-proxy's default. Click it to set an explicit value."
                           Visibility="{Binding IsSet, Converter={StaticResource InverseBoolToVisibility}}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="LongEditorTemplate">
            <ui:NumberBox Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                          MaxDecimalPlaces="0"
                          PlaceholderText="{Binding DefaultDisplay}"
                          LostFocus="NumberEditor_LostFocus"
                          MinWidth="140" HorizontalAlignment="Left" />
        </DataTemplate>

        <DataTemplate x:Key="FloatEditorTemplate">
            <ui:NumberBox Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                          MaxDecimalPlaces="6"
                          PlaceholderText="{Binding DefaultDisplay}"
                          LostFocus="NumberEditor_LostFocus"
                          MinWidth="140" HorizontalAlignment="Left" />
        </DataTemplate>

        <DataTemplate x:Key="StringEditorTemplate">
            <ui:TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                        PlaceholderText="{Binding DefaultDisplay}"
                        LostFocus="StringEditor_LostFocus"
                        MinWidth="260" HorizontalAlignment="Stretch" />
        </DataTemplate>

        <DataTemplate x:Key="StringArrayEditorTemplate">
            <!-- One item per line (tested StringArrayToLinesConverter). -->
            <TextBox Text="{Binding Value, Converter={StaticResource ArrayToLines}, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                     AcceptsReturn="True"
                     FontFamily="Consolas"
                     MinHeight="52" MaxHeight="110" MinWidth="260"
                     VerticalScrollBarVisibility="Auto"
                     LostFocus="LinesEditor_LostFocus"
                     ToolTip="One entry per line."
                     HorizontalAlignment="Stretch" />
        </DataTemplate>

        <DataTemplate x:Key="RawOnlyEditorTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="No structured editor in this phase"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontStyle="Italic"
                           VerticalAlignment="Center" Margin="0,0,10,0" />
                <ui:Button Content="Open Raw view" Click="OpenRawView_Click" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ======================= Banners (E3 outcome states; null = hidden) -->
        <StackPanel Grid.Row="0">

            <!-- Load failure (distinct from a parse failure): the whole editor below is
                 disabled via the LoadFailed trigger; Retry is an explicit re-read. -->
            <Grid Visibility="{Binding LoadError, Converter={StaticResource NullToVisibility}}"
                  Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:InfoBar Grid.Column="0"
                            Title="Config file could not be loaded"
                            Message="{Binding LoadError}"
                            Severity="Error" IsOpen="True" IsClosable="False" />
                <ui:Button Grid.Column="1" Content="Retry"
                           Click="ReloadButton_Click"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </Grid>

            <!-- F20 mirror (P5b-E1): the save path refused to talk to a helper on a
                 different protocol version. -->
            <ui:InfoBar Title="Helper version incompatible"
                        Message="{Binding HelperIncompatibleMessage}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding HelperIncompatibleMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <!-- BE-6 conflict: nothing was written; the edits stay in the editor and
                 [Reload] is the user's explicit choice (E3). -->
            <Grid Visibility="{Binding ConflictMessage, Converter={StaticResource NullToVisibility}}"
                  Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:InfoBar Grid.Column="0"
                            Title="Config changed on disk"
                            Message="{Binding ConflictMessage}"
                            Severity="Warning" IsOpen="True" IsClosable="False" />
                <ui:Button Grid.Column="1" Content="Reload"
                           Appearance="Primary"
                           Click="ReloadButton_Click"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </Grid>

            <!-- Persistent, never-green post-save states (§7.3). -->
            <ui:InfoBar Title="Proxy rejected the new config"
                        Message="{Binding ProxyRejectedMessage}"
                        Severity="Error" IsOpen="True" IsClosable="False"
                        Visibility="{Binding ProxyRejectedMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <ui:InfoBar Title="Restart failed"
                        Message="{Binding RestartFailedMessage}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding RestartFailedMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <!-- Save refusals / transport losses: the message shown verbatim (IC-10). -->
            <ui:InfoBar Title="Save failed"
                        Message="{Binding SaveError}"
                        Severity="Error" IsOpen="True" IsClosable="False"
                        Visibility="{Binding SaveError, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <!-- Client-side OPSEC block mirror (P5b-U1/F24) — UX only; the helper
                 enforces the same rules server-side regardless. -->
            <ui:InfoBar Title="Save blocked"
                        Message="{Binding SaveBlockedReason}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding SaveBlockedReason, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <!-- Transient "saved" notice (cleared by the next edit or attempt). -->
            <ui:InfoBar Title="Saved"
                        Message="{Binding SaveNotice}"
                        Severity="Success" IsOpen="True" IsClosable="False"
                        Visibility="{Binding SaveNotice, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />
        </StackPanel>

        <!-- ======================= Editor chrome + content: disabled as a whole while
             the load itself failed (E1's LoadFailed state) OR while a Save & apply is
             in flight (IsBusy) — an edit typed mid-save would be clobbered by the
             outcome's reload; the grey-out doubles as the busy cue. -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="IsEnabled" Value="True" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding LoadFailed}" Value="True">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- =================== Subbar: view toggle, search, status badge, actions -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="StructuredViewToggle"
                                 Content="Structured"
                                 GroupName="ConfigEditorView"
                                 IsChecked="True"
                                 Margin="0,0,4,0" />
                    <RadioButton x:Name="RawViewToggle"
                                 Content="Raw TOML"
                                 GroupName="ConfigEditorView" />
                </StackPanel>

                <ui:TextBox Grid.Column="1"
                            Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Search settings…"
                            Width="230" VerticalAlignment="Center" Margin="14,0,0,0" />

                <!-- Status badge: Valid / N errors / Blocked (tested multi-converter). -->
                <ui:Badge Grid.Column="2" VerticalAlignment="Center" Margin="14,0,0,0">
                    <ui:Badge.Appearance>
                        <MultiBinding Converter="{StaticResource StatusBadge}" ConverterParameter="Appearance">
                            <Binding Path="IsValid" />
                            <Binding Path="ValidationIssues" />
                            <Binding Path="SaveBlockedReason" />
                        </MultiBinding>
                    </ui:Badge.Appearance>
                    <ui:Badge.Content>
                        <MultiBinding Converter="{StaticResource StatusBadge}" ConverterParameter="Text">
                            <Binding Path="IsValid" />
                            <Binding Path="ValidationIssues" />
                            <Binding Path="SaveBlockedReason" />
                        </MultiBinding>
                    </ui:Badge.Content>
                </ui:Badge>

                <ui:Button Grid.Column="4"
                           Content="{x:Static vm:ConfigurationViewModel.RevertLabel}"
                           Command="{Binding RevertCommand}"
                           Margin="0,0,8,0" />
                <ui:Button Grid.Column="5"
                           Content="Save &amp; apply"
                           Appearance="Primary"
                           Command="{Binding SaveAndApplyCommand}" />
            </Grid>

            <!-- =================== Structured view: curated section nav + entry form -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsChecked, ElementName=StructuredViewToggle, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- A4 groups; filtering hides empty sections (§8.3). Current-item sync
                     keeps a section selected when the filter replaces the list. -->
                <ListBox x:Name="SectionNav"
                         ItemsSource="{Binding VisibleSections}"
                         IsSynchronizedWithCurrentItem="True"
                         DisplayMemberPath="Name" />

                <Grid Grid.Column="1" Margin="14,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 5g-3: section header + the group's optional plain-language
                         explainer (ConfigSectionViewModel.Description; null = collapsed). -->
                    <StackPanel Grid.Row="0" Margin="0,2,0,8">
                        <TextBlock Text="{Binding SelectedItem.Name, ElementName=SectionNav}"
                                   FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding SelectedItem.Description, ElementName=SectionNav}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Visibility="{Binding SelectedItem.Description, ElementName=SectionNav, Converter={StaticResource NullToVisibility}, FallbackValue=Collapsed}" />
                    </StackPanel>

                    <!-- Greys out while the raw text has parse errors (E1) — display-only
                         last-good values until the raw TOML is fixed. Virtualized (F1). -->
                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding SelectedItem.VisibleEntries, ElementName=SectionNav}"
                                  IsEnabled="{Binding IsStructuredEditable}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ScrollViewer.CanContentScroll="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              CanContentScroll="True"
                                              Focusable="False">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SettingEntryViewModel}">
                                <Border BorderBrush="#22808080" BorderThickness="0,0,0,1" Padding="0,9,0,9">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="280" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding KeyPath}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Border CornerRadius="4" Padding="5,1" Margin="8,0,0,0"
                                                        Background="#40E9A13B"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding Deprecated, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                               Text="{Binding ReplacedBy, Converter={StaticResource DeprecatedChipText}}" />
                                                </Border>
                                            </StackPanel>
                                            <!-- 5g-6/5j: plain-language line FIRST — the primary
                                                 explanation, pinned to the primary theme brush (the
                                                 KeyPath heading above uses the same, so neither can
                                                 bake to black in dark mode); the Doc below is secondary. -->
                                            <TextBlock Text="{Binding Friendly}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"
                                                       Visibility="{Binding Friendly, Converter={StaticResource NullToVisibility}}" />
                                            <TextBlock Text="{Binding Doc}"
                                                       FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding DefaultDisplay, StringFormat='Default: {0}'}"
                                                       FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontStyle="Italic"
                                                       TextWrapping="Wrap" Margin="0,1,0,0" />
                                        </StackPanel>

                                        <ContentControl Grid.Column="1"
                                                        Content="{Binding}"
                                                        VerticalAlignment="Center"
                                                        Focusable="False">
                                            <ContentControl.Style>
                                                <Style TargetType="ContentControl">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource RawOnlyEditorTemplate}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ValueType}" Value="Bool">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource BoolEditorTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ValueType}" Value="Long">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource LongEditorTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ValueType}" Value="Float">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource FloatEditorTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ValueType}" Value="String">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource StringEditorTemplate}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ValueType}" Value="StringArray">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource StringArrayEditorTemplate}" />
                                                        </DataTrigger>
                                                        <!-- LAST so it beats the type triggers (P5b-E3). -->
                                                        <DataTrigger Binding="{Binding IsRawOnly}" Value="True">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource RawOnlyEditorTemplate}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ContentControl.Style>
                                        </ContentControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>

            <!-- =================== Raw view: plain TextBox, dark pane (P5b-U2, locked
                 visual language). Every keystroke hits the VM (E2's debounce validates). -->
            <TextBox Grid.Row="1"
                     x:Name="RawEditor"
                     Text="{Binding RawText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding IsChecked, ElementName=RawViewToggle, Converter={StaticResource BoolToVisibility}}"
                     AcceptsReturn="True"
                     AcceptsTab="False"
                     FontFamily="Consolas"
                     FontSize="13"
                     Background="#1e1e2e"
                     Foreground="#cdd6f4"
                     CaretBrush="#cdd6f4"
                     BorderThickness="0"
                     Padding="12"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     SpellCheck.IsEnabled="False" />

            <!-- =================== Validation panel below the editor (P5b-U2): the FULL
                 local issue list + OPSEC warnings with severity glyphs (E2); hidden only
                 while BOTH lists are empty. -->
            <Border Grid.Row="2"
                    BorderBrush="#33808080" BorderThickness="1" CornerRadius="6"
                    Padding="10" Margin="0,10,0,0" MaxHeight="170">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasItems, ElementName=OpsecConcernsList}" Value="False" />
                                    <Condition Binding="{Binding HasItems, ElementName=SchemaIssuesList}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Collapsed" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="VALIDATION"
                                   FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />

                        <!-- OPSEC concerns first: they carry the protection stakes (P5b-U1). -->
                        <ItemsControl x:Name="OpsecConcernsList" ItemsSource="{Binding OpsecConcerns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Text="{Binding Severity, Converter={StaticResource SeverityToGlyph}}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding KeyPath}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Schema issues: the full local list — the wire only ever
                             carries the first error, the panel's richness is local (E2). -->
                        <ItemsControl x:Name="SchemaIssuesList" ItemsSource="{Binding ValidationIssues}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Text="{Binding Severity, Converter={StaticResource SeverityToGlyph}}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding KeyPath}"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
