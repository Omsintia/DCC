<UserControl x:Class="DnsCryptControl.UI.Views.AnonymizedDnsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:DnsCryptControl.UI.Converters"
    xmlns:vm="clr-namespace:DnsCryptControl.UI.ViewModels"
    mc:Ignorable="d"
    d:DesignHeight="720" d:DesignWidth="1000">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:InverseBooleanConverter x:Key="InverseBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ======================= Banners (banners-on-top; null = hidden). -->
        <StackPanel Grid.Row="0">

            <Grid Visibility="{Binding LoadError, Converter={StaticResource NullToVisibility}}"
                  Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:InfoBar Grid.Column="0"
                            Title="Config could not be loaded"
                            Message="{Binding LoadError}"
                            Severity="Error" IsOpen="True" IsClosable="False" />
                <ui:Button Grid.Column="1" Content="Retry"
                           Click="ReloadButton_Click"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </Grid>

            <!-- Read-only "hand-managed config — use the raw editor" state (IC-12). -->
            <ui:InfoBar Title="Routes are read-only"
                        Message="{Binding ReadOnlyReason}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding ReadOnlyReason, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <!-- Pristine zero-pool guard (AnonDNS-on but no live pool). -->
            <ui:InfoBar Title="No live resolvers"
                        Message="{Binding ZeroPoolBannerMessage}"
                        Severity="Error" IsOpen="True" IsClosable="False"
                        Visibility="{Binding ZeroPoolBannerMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <!-- Load-time strictness mirror + one-click fix. -->
            <Grid Visibility="{Binding StrictBannerMessage, Converter={StaticResource NullToVisibility}}"
                  Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:InfoBar Grid.Column="0"
                            Title="Anonymization is not strict"
                            Message="{Binding StrictBannerMessage}"
                            Severity="Warning" IsOpen="True" IsClosable="False" />
                <ui:Button Grid.Column="1" Content="Apply strict settings"
                           Click="ApplyStrictFix_Click"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </Grid>

            <!-- DoH warning + one-click fix. -->
            <Grid Visibility="{Binding DohBannerMessage, Converter={StaticResource NullToVisibility}}"
                  Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:InfoBar Grid.Column="0"
                            Title="DoH bypasses anonymization"
                            Message="{Binding DohBannerMessage}"
                            Severity="Warning" IsOpen="True" IsClosable="False" />
                <ui:Button Grid.Column="1" Content="Disable DoH"
                           Click="ApplyDohFix_Click"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </Grid>

            <ui:InfoBar Title="Config changed on disk"
                        Message="{Binding ConflictMessage}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding ConflictMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <ui:InfoBar Title="Helper version incompatible"
                        Message="{Binding HelperIncompatibleMessage}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding HelperIncompatibleMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <ui:InfoBar Title="Proxy rejected the new config"
                        Message="{Binding ProxyRejectedMessage}"
                        Severity="Error" IsOpen="True" IsClosable="False"
                        Visibility="{Binding ProxyRejectedMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <ui:InfoBar Title="Restart failed"
                        Message="{Binding RestartFailedMessage}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding RestartFailedMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <ui:InfoBar Title="Save failed"
                        Message="{Binding SaveError}"
                        Severity="Error" IsOpen="True" IsClosable="False"
                        Visibility="{Binding SaveError, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <ui:InfoBar Title="Save blocked"
                        Message="{Binding SaveBlockedReason}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding SaveBlockedReason, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <ui:InfoBar Title="Heads up"
                        Message="{Binding ZeroPoolWarning}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding ZeroPoolWarning, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <ui:InfoBar Title="Route not added"
                        Message="{Binding AddRouteError}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding AddRouteError, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <ui:InfoBar Title="Saved"
                        Message="{Binding SaveNotice}"
                        Severity="Success" IsOpen="True" IsClosable="False"
                        Visibility="{Binding SaveNotice, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />

            <!-- FIX #1 (v1.2.0): the post-apply route-verification warning. The green "Saved" bar above
                 only proves the WRITE landed; this bar is the honest signal when the applied route does
                 not actually RESOLVE (the continuous self-check false-greens on a dead route). -->
            <ui:InfoBar Title="DNS not resolving"
                        Message="{Binding PostApplyWarning}"
                        Severity="Warning" IsOpen="True" IsClosable="False"
                        Visibility="{Binding PostApplyWarning, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,8" />
        </StackPanel>

        <!-- ======================= Content: disabled as a whole while the load failed OR a save is
             in flight (IsBusy). -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="IsEnabled" Value="True" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding LoadFailed}" Value="True">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- =================== Save / Revert bar. -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                <ui:Button Content="{x:Static vm:AnonymizedDnsViewModel.RevertLabel}"
                           Command="{Binding RevertCommand}"
                           Margin="0,0,8,0" />
                <ui:Button Content="Save &amp; apply"
                           Appearance="Primary"
                           Command="{Binding SaveAndApplyCommand}" />
            </StackPanel>

            <!-- =================== Explainer + honest anonymization headline. -->
            <ui:InfoBar Grid.Row="1"
                        Title="Anonymized DNS"
                        Message="{Binding AnonymizationStateText}"
                        Severity="Informational" IsOpen="True" IsClosable="False"
                        Margin="0,0,0,10" />

            <!-- =================== Toggles. -->
            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Enable anonymized DNS" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Your DNS questions travel through a relay, so a server with a working route can't see who asked. This covers two families: classic DNSCrypt relays, and ODoH (Oblivious DoH) — an ODoH server can ONLY be reached by pairing it with an ODoH relay in a route below (add the ODoH lists from the Resolvers tab first). The coverage note below shows which servers are routed — unrouted ones still see your address."
                                   FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1"
                                     IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                     IsEnabled="{Binding IsRoutesReadOnly, Converter={StaticResource InverseBool}}"
                                     Click="EnableToggle_Click" />
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Skip resolvers incompatible with anonymization (strict)" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Drop servers a relay can't reach, so nothing quietly falls back to a direct, un-anonymized connection."
                                   FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                    <!-- Strict = the strict bundle is applied = the strict banner is null. There is no
                         un-strict path in the VM (strict is a one-way hardening), so the click always
                         applies the strict bundle; the checked-state reflects the banner one-way. -->
                    <ui:ToggleSwitch Grid.Column="1"
                                     x:Name="SkipIncompatibleToggle"
                                     Click="StrictToggle_Click">
                        <ui:ToggleSwitch.Style>
                            <!-- BasedOn is REQUIRED: a local Style without it discards the WPF-UI default
                                 ToggleSwitch template, so the switch renders as a bare unstyled sliver
                                 (found live in the VM run — same trap as the Coverage InfoBar below). -->
                            <Style TargetType="ui:ToggleSwitch" BasedOn="{StaticResource {x:Type ui:ToggleSwitch}}">
                                <Setter Property="IsChecked" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StrictBannerMessage, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                        <Setter Property="IsChecked" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:ToggleSwitch.Style>
                    </ui:ToggleSwitch>
                </Grid>
            </StackPanel>

            <!-- =================== Coverage summary. -->
            <ui:InfoBar Grid.Row="3"
                        Title="Coverage"
                        Message="{Binding CoverageSummary}"
                        IsOpen="True" IsClosable="False"
                        Visibility="{Binding CoverageSummary, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,10">
                <ui:InfoBar.Style>
                    <!-- BasedOn is REQUIRED: a local Style without it discards the WPF-UI default
                         InfoBar template, so the coverage banner renders nothing (found live, Phase 5c VM run). -->
                    <Style TargetType="ui:InfoBar" BasedOn="{StaticResource {x:Type ui:InfoBar}}">
                        <Setter Property="Severity" Value="Success" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasUncoveredServers}" Value="True">
                                <Setter Property="Severity" Value="Warning" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:InfoBar.Style>
            </ui:InfoBar>

            <!-- =================== Routes table (add/remove; server + via). -->
            <Border Grid.Row="4" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="8"
                    IsEnabled="{Binding IsRoutesReadOnly, Converter={StaticResource InverseBool}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ROUTE — SERVER" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="VIA RELAY(S)" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Routes}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ScrollViewer.CanContentScroll="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="True" Focusable="False">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:RouteRowViewModel}">
                                <Grid Margin="0,3" >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1.6*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ServerName}" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Via}" VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="8" Padding="6,1" Margin="0,1,3,1"
                                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                                    <TextBlock Text="{Binding}" FontSize="10" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:Button Content="Edit"
                                                   Click="EditRoute_Click"
                                                   Tag="{Binding}" VerticalAlignment="Center" />
                                        <ui:Button Content="Remove"
                                                   Click="RemoveRoute_Click"
                                                   Tag="{Binding}" VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- =================== Add-route builder (captions + server combo + via combo + Add + empty-state). -->
            <StackPanel Grid.Row="5" Margin="0,10,0,0"
                        IsEnabled="{Binding IsRoutesReadOnly, Converter={StaticResource InverseBool}}">
                <!-- Captions: the routes-table headers sit above the LIST, not these builder combos. These
                     label which side is the SERVER vs the RELAY and reveal the '*' = any-relay shortcut. -->
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ADD A ROUTE — PICK A SERVER" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="1" Text="THROUGH A RELAY  ·  * = any compatible relay" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              x:Name="AddServerCombo"
                              ItemsSource="{Binding ServerCandidates}"
                              DisplayMemberPath="Name"
                              IsEditable="True"
                              SelectionChanged="AddServerCombo_SelectionChanged"
                              Margin="0,0,6,0" />
                    <ComboBox Grid.Column="1"
                              x:Name="AddViaCombo"
                              ItemsSource="{Binding AddViaCandidates}"
                              IsEditable="True"
                              Margin="0,0,6,0" />
                    <ui:Button Grid.Column="2" Content="Add route"
                               Click="AddRoute_Click" />
                </Grid>
                <!-- Persistent scope hint: the server combo lists ONLY anonymizable servers (DNSCrypt + ODoH
                     targets). DoH servers are deliberately excluded because a relay cannot carry DoH — but
                     that exclusion was SILENT, so a user searching a DoH server here saw it "vanish". State
                     the scope up front rather than let the empty result read as a bug. -->
                <TextBlock Text="Only DNSCrypt and ODoH servers appear here — DoH servers can't be anonymized (a relay can't carry DoH), so they aren't listed."
                           FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,4,0,0" />
                <!-- The relay defaults to '*'. State the trade-off so the default isn't silent: '*' is the
                     reliable choice (auto-picks a working relay, skips dead ones); a single pinned relay is
                     stronger anonymization but fails hard if that one relay stops carrying queries. -->
                <TextBlock Text="The relay defaults to '*' (any compatible relay) — the most reliable choice: the proxy picks a working relay and skips dead ones. For the strongest anonymization, pick a specific relay run by a different operator than the server — but if that one relay fails, this route stops resolving until you change it."
                           FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,4,0,0" />
                <!-- Explains a via list that is only '*' (e.g. an ODoH server picked before its relay list is cached). -->
                <TextBlock Text="{Binding AddViaEmptyHint}"
                           Visibility="{Binding AddViaEmptyHint, Converter={StaticResource NullToVisibility}}"
                           FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
